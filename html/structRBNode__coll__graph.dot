</TABLE>> ,fontcolor="grey" ];
  Node2 [id="Node000002",label="Ship",height=0.2,width=0.4,color="gray40", fillcolor="white", style="filled",URL="$structShip.html",tooltip="Структура, содержащая информацию о корабле."];
